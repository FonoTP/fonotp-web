{
  "name": "fonotp-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server/index.js",
    "dev:voice-runtime-demo": "npm --prefix voice-runtime-demo run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start:server": "node server/index.js",
    "start:voice-runtime-demo": "npm --prefix voice-runtime-demo run start",
    "db:setup": "psql \"$DATABASE_URL\" -f server/db/schema.sql && psql \"$DATABASE_URL\" -f server/db/seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
